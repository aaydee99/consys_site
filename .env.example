# =============================================================================
# Cloudflare R2 — same bucket, two ways to use it
# =============================================================================
#
# 1) PUBLIC (this React app in the browser)
#    - In Cloudflare: R2 → your bucket → Settings → Public access → enable and
#      note the public URL (r2.dev or custom domain).
#    - Set VITE_R2_PUBLIC_URL below (no trailing slash). Vite embeds only this
#      string in the client — never secret keys.
#    - Visitors load:  VITE_R2_PUBLIC_URL + /images/... and /videos/...
#
# 2) S3 API (Node scripts: npm run r2:verify, npm run r2:upload)
#    - Same bucket, authenticated with R2 API token credentials (S3-compatible).
#    - Use for uploads and automation only. Keep R2_* vars out of VITE_*.
#
# =============================================================================

# --- Browser (safe to expose; embedded in built JS) ---
VITE_R2_PUBLIC_URL=
VITE_R2_BUCKET_NAME=consys-storage

# Object keys: images/<filename>, videos/<filename> — see src/data/iiapMediaFilenames.json

# --- Node / S3 API only (never use VITE_ prefix for these) ---
# Dashboard → R2 → Manage R2 API Tokens → Create API token (Object Read & Write or Admin)
# Endpoint format:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_S3_ENDPOINT=https://667bbb23906297a8ae02735564bdc7a5.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=e9564b04e7b6ec9fdb54484f8af17f03
R2_SECRET_ACCESS_KEY=5d55b2ca62f63186d6ee20bec44b5bceaaa7658fed1187d8af6e57e52e2b4203
R2_BUCKET_NAME=consys-storage
